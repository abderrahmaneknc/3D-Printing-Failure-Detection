generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PrinterStatus {
  IDLE
  PRINTING
  PAUSED
  OFFLINE
}

enum CommandStatus {
  SENT
  SUCCESS
  ERROR
}

enum JobStatus {
  QUEUED
  PRINTING
  PAUSED
  DONE
  FAILED
  CANCELLED
}

enum MaintenanceType {
  REPAIR
  ROUTINE
  UPGRADE
}

enum InventoryType {
  ORDER
  REDUCTION
}

enum MaterialType {
  PLA
  PLA_PLUS
  ABS
  PETG
  TPU
  ASA
}

enum PrinterSelectionMode {
  NEXT_AVAILABLE_WITH_SPECIFIC_TAG
  SPECIFIC_PRINTER
}

model Printer {
  id             String        @id @default(uuid())
  name           String
  model          String
  printerType    String
  status         PrinterStatus
  ipAddress      String
  nozzleDiameter Float
  bedTemp        Float
  nozzleTemp     Float
  cameraLink     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  commandLogs     CommandLog[]
  maintenanceLogs MaintenanceLog[]
  jobs            PrintJob[]
  tags            PrinterTag[]
}

model Tag {
  id    String  @id @default(uuid())
  name  String
  color String?

  printers PrinterTag[]
}

model PrinterTag {
  printerId String
  tagId     String

  printer Printer @relation(fields: [printerId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([printerId, tagId])
}

model CommandLog {
  id        String        @id @default(uuid())
  printerId String
  commandId String?       
  rawCommand String  
  response  String?
  status    CommandStatus

  createdAt DateTime @default(now())

  printer      Printer      @relation(fields: [printerId], references: [id])
  gcodeCommand GcodeCommand? @relation(fields: [commandId], references: [id])
}

model GcodeCommand {
  id         String      @id @default(uuid())
  name       String
  command    String
  commandLogs CommandLog[]
}

model MaintenanceLog {
  id          String          @id @default(uuid())
  printerId   String
  type        MaintenanceType
  description String
  cost        Float?

  createdAt DateTime @default(now())

  printer Printer @relation(fields: [printerId], references: [id])
}

model PrintJob {
  id        String @id @default(uuid())
  printerId String?
  fileId    String
  profileId String?
  status   JobStatus
  progress Int
  startedAt     DateTime?
  finishedAt    DateTime?
  estimatedTime Int?
  printerSelectionMode PrinterSelectionMode
  queuePosition Int
  requiredTagIds String[]
  createdAt DateTime @default(now())
  printer  Printer?           @relation(fields: [printerId], references: [id])
  profile   FilamentProfile? @relation(fields: [profileId], references: [id])
  part     Part              @relation(fields: [fileId], references: [id])
}

model Part {
  id             String @id @default(uuid())
  image          String
  title          String
  duration       Int
  nozzleDiameter Float
  filamentUsed   Float

  createdAt DateTime   @default(now())
  printJobs PrintJob[]
}

model FilamentProfile {
  id       String       @id @default(uuid())
  material MaterialType
  name     String
  color    String
  roleSize Float

  jobs      PrintJob[]
  inventory Inventory[]
}

model Inventory {
  id          String        @id @default(uuid())
  orderNumber String
  updateType  InventoryType
  quantity    Int
  totalCost   Float?

  date DateTime

  profileId String
  profile   FilamentProfile @relation(fields: [profileId], references: [id])
}
